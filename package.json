{
  "name": "master-of-coin-mini-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:html && npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./styles.css --minify",
    "build:html": "node scripts/build-html.js",
    "build:js": "tsc --noEmit && esbuild src/main.ts --bundle --format=iife --target=es2020 --outfile=app.js",
    "dev": "npm run build && python3 -m http.server ${PORT:-8080}"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
